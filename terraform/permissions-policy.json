{
    "Version": "2012-10-17",
    "Statement": [
      {
        "Effect": "Allow",
        "Action": [
          "s3:PutObject",
          "s3:GetObject",
          "s3:ListBucket"
        ],
        "Resource": [
          "arn:aws:s3:::ec2-shutdown-lambda-bucket/*",
          "arn:aws:s3:::ec2-shutdown-lambda-bucket/*"
        ]
      },
      {
        "Effect": "Allow",
        "Action": [
          "cloudformation:*",
          "lambda:*",
          "dynamodb:*",
          "iam:PassRole"
        ],
        "Resource": "*"
      }
    ]
  }