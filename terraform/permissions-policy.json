{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Effect": "Allow",
      "Action": [
        "s3:PutObject",
        "s3:GetObject",
        "s3:ListBucket"
      ],
      "Resource": [
        "arn:aws:s3:::ec2-shutdown-lambda-bucket",
        "arn:aws:s3:::ec2-shutdown-lambda-bucket/*"
      ]
    },
    {
      "Effect": "Allow",
      "Action": [
        "rekognition:*",
        "lambda:*",
        "cloudformation:*",
        "dynamodb:*",
        "iam:PassRole",
        "sts:GetCallerIdentity"
      ],
      "Resource": "*"
    },
    {
      "Effect": "Allow",
      "Action": [
        "logs:CreateLogGroup",
        "logs:CreateLogStream",
        "logs:PutLogEvents"
      ],
      "Resource": "arn:aws:logs:*:*:*"
    },
    {
      "Effect": "Allow",
      "Action": [
        "ec2:Describe*",
        "iam:List*",
        "iam:Get*",
        "s3:ListAllMyBuckets"
      ],
      "Resource": "*"
    },
    {
      "Effect": "Allow",
      "Action": [
        "terraform:*"
      ],
      "Resource": "*"
    }
  ]
}
