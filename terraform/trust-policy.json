{
    "Version": "2012-10-17",
    "Statement": [
      {
        "Effect": "Allow",
        "Principal": {
          "Federated": "arn:aws:iam::615299732970:oidc-provider/token.actions.githubusercontent.com"
        },
        "Action": "sts:AssumeRoleWithWebIdentity",
        "Condition": {
          "StringEquals": {
            "token.actions.githubusercontent.com:aud": "sts.amazonaws.com"
          },
          "StringLike": {
            "token.actions.githubusercontent.com:sub": [
              "repo:shehuj/redLUIT_oct2025_AWSRekognition:ref:refs/heads/main",
              "repo:shehuj/redLUIT_oct2025_AWSRekognition:ref:refs/heads/*"
            ]
          }
        }
      }
    ]
  }
